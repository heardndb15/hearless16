{
  "version": 2,
  "buildCommand": "cd landing && npm install && npm run build",
  "outputDirectory": "landing/.next",
  "framework": "nextjs",
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    }
  ]
}
